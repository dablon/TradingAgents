# TradingAgents Configuration

# LLM Provider - Using Minimax (OpenAI-compatible)
OPENAI_API_KEY=YOUR_MINIMAX_API_KEY_HERE
llm_provider=openai
backend_url=https://api.minimax.chat/v1

# Alternative Minimax endpoints (uncomment if above doesn't work)
# backend_url=https://api.minimaxi.chat/v1

# Model configuration
deep_think_llm=miniMax-Text-01
quick_think_llm=miniMax-Text-01

# Debate settings
max_debate_rounds=1
max_risk_discuss_rounds=1

# Data vendor
core_stock_apis=yfinance
technical_indicators=yfinance
fundamental_data=yfinance
news_data=yfinance
